rules_version = '2';

// MomOS — Firestore security rules
// Household-scoped, role-based access. A user only ever sees data for
// households they are an active member of. Writers must be owner or helper;
// viewers are read-only. The audit log is append-only.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function memberPath(hid) {
      return /databases/$(database)/documents/households/$(hid)/members/$(request.auth.uid);
    }
    function isMember(hid) {
      return signedIn()
        && exists(memberPath(hid))
        && get(memberPath(hid)).data.status == 'active';
    }
    function myRole(hid) {
      return get(memberPath(hid)).data.role;
    }
    function canWrite(hid) {
      return isMember(hid) && (myRole(hid) == 'owner' || myRole(hid) == 'helper');
    }
    function isOwner(hid) {
      return isMember(hid) && myRole(hid) == 'owner';
    }
    function invitePath(hid, token) {
      return /databases/$(database)/documents/households/$(hid)/invites/$(token);
    }

    // Lightweight public profile (display name), readable by any signed-in user.
    match /users/{uid} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == uid;
    }

    match /households/{hid} {
      allow read: if isMember(hid);
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isOwner(hid);

      // Members: owner manages everyone; the owner bootstraps their own
      // membership at creation; anyone else self-joins with a valid invite.
      match /members/{uid} {
        allow read: if isMember(hid);
        allow update, delete: if isOwner(hid);
        allow create: if isOwner(hid)
          || (
            signedIn() && request.auth.uid == uid
            && request.resource.data.role == 'owner'
            && get(/databases/$(database)/documents/households/$(hid)).data.ownerId == request.auth.uid
          )
          || (
            signedIn() && request.auth.uid == uid
            && request.resource.data.status == 'active'
            && exists(invitePath(hid, request.resource.data.inviteToken))
            && get(invitePath(hid, request.resource.data.inviteToken)).data.status == 'pending'
            && get(invitePath(hid, request.resource.data.inviteToken)).data.expiresAt > request.time
            && request.resource.data.role == get(invitePath(hid, request.resource.data.inviteToken)).data.role
          );
      }

      // Invites: owner creates/revokes; any signed-in user may read one to accept.
      match /invites/{token} {
        allow read: if signedIn();
        allow create, update, delete: if isOwner(hid);
      }

      // Records: the synced household data (items, tasks, etc.). Viewers read-only.
      match /records/{doc} {
        allow read: if isMember(hid);
        allow create, update, delete: if canWrite(hid);
      }

      // Audit log: append-only, never edited or deleted.
      match /audit/{doc} {
        allow read: if isMember(hid);
        allow create: if isMember(hid);
        allow update, delete: if false;
      }
    }
  }
}
